# Server
PORT=3101

# ATEM Fairlight audio config
FAIRLIGHT_INPUT=1301
FAIRLIGHT_SOURCE=-65280
FAIRLIGHT_FADER_GAIN=-220

# OBS WebSocket (built into OBS v28+)
OBS_URL=ws://localhost:4455
OBS_PASSWORD=

# OBS program preview in idle MSG box
OBS_PREVIEW_INTERVAL=3000
OBS_PREVIEW_WIDTH=320
OBS_PREVIEW_QUALITY=30
